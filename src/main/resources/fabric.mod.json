{
	"schemaVersion": 1,
	"id": "simplemeasure",
	"version": "${version}",
	"name": "SimpleMeasure",
	"description": "A simple Fabric mod for easy measuring ",
	"authors": [
		"Benjas333"
	],
	"contact": {
		"homepage": "https://x.com/Benjas333Dev",
		"sources": "https://github.com/Benjas333/SimpleMeasure-Fabric"
	},
	"license": "CC0-1.0",
	"icon": "assets/simplemeasure/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"benjas333.simplemeasure.SimpleMeasure"
		],
		"client": [
			"benjas333.simplemeasure.client.SimpleMeasureClient"
		]
	},
	"mixins": [
		"simplemeasure.mixins.json",
		{
			"config": "simplemeasure.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}